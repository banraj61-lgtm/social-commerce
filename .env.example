# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://socialbazaar:socialbazaar_dev@localhost:5432/socialbazaar?schema=public"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO (S3-compatible storage) ───────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="socialbazaar"
MINIO_SECRET_KEY="socialbazaar_dev"
MINIO_BUCKET="socialbazaar-uploads"
MINIO_USE_SSL=false

# ─── Meilisearch ─────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="socialbazaar_dev_key"

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── API Server ──────────────────────────────────────────────
API_PORT=4000
API_HOST="0.0.0.0"

# ─── Next.js Apps ────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/trpc"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SELLER_URL="http://localhost:3001"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# ─── Node Environment ───────────────────────────────────────
NODE_ENV="development"
